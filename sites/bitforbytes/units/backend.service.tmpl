[Unit]
Description=VeriLog backend (Express :@PORT@)
After=network-online.target

[Service]
Type=simple
WorkingDirectory=@HOME@/verilog-src/backend
Environment=NODE_ENV=development
Environment=PORT=@PORT@
Environment=PATH=@BIN@:/usr/local/bin:/usr/bin:/bin
ExecStart=/usr/bin/env npm run dev
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
